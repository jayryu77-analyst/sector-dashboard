# Telegram credentials
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Alert settings
ALERT_THRESHOLD=2.0
ALERT_PERIOD=1d

# Optional: External news API keys (store in .env, never commit)
# NewsAPI: https://newsapi.org (register → get free key)
NEWSAPI_KEY=your_newsapi_key_here
# NewsData.io: https://newsdata.io (register → get free key)
NEWSDATA_KEY=your_newsdata_key_here
# Naver News Search: https://developers.naver.com/apps/#/register (get Client ID & Secret)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
